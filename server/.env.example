# Puerto del servidor (el plan usa 3000 en la doc de red de la app)
PORT=3000

# Conexión a MongoDB — local o Atlas. Ejemplos:
#   local:  mongodb://127.0.0.1:27017/prode-mundial
#   Atlas:  mongodb+srv://usuario:pass@cluster.xxxx.mongodb.net/prode-mundial
MONGO_URI=mongodb://127.0.0.1:27017/prode-mundial

# Secreto para firmar/verificar los JWT. CAMBIALO por algo largo y aleatorio.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# Origen del frontend permitido por CORS.
# Expo web suele servir en 8081; ajustalo según donde corra la app.
CLIENT_ORIGIN=http://localhost:8081

# Nivel de log de winston (info | warn | error | debug)
LOG_LEVEL=info
